# --- Scheduler API ---
# Preferred: set the key from the admin console (stored encrypted in the DB).
# This env var is a fallback. Blank = simulated data (sample_items.json).
SCHEDULER_API_KEY=
SCHEDULER_API_URL=https://schedulerapi.edutl.hpe.com/v1/items

# --- Admin console (shadow route) ---
# Obscure the admin path in prod, e.g. ADMIN_PATH=ops-7f3a
ADMIN_PATH=admin
# Session signing key — set a long random value in prod.
SECRET_KEY=change-me-to-a-long-random-string
# Fernet key for encrypting the stored API key. If unset, one is generated at
# data/secret.key. KEEP IT SAFE and back it up. Overrides the key file if set.
LABPORTAL_FERNET_KEY=
# Cookies are Secure by default (HTTPS). Set false only for plain-HTTP local dev.
COOKIE_SECURE=true
